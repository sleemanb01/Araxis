rules_version = '2';

// Mima Firestore security rules.
// Principle: deny by default; only authenticated technicians can read/write,
// and writes are validated. Tighten further with custom claims (roles) later.

service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Helpers ----
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerifiedPhone() {
      // Phone-auth users always have a phone_number token field.
      return isSignedIn() && request.auth.token.phone_number != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ---- Users: owner can read/write their own profile; profiles are
    //      readable by any signed-in user (to view providers). ----
    match /users/{userId} {
      allow read:  if isSignedIn();
      allow write: if isOwner(userId);

      // Reviews of a provider: any verified user can read; a verified user
      // can create a review authored as themselves; no edits/deletes.
      match /reviews/{reviewId} {
        allow read:   if isVerifiedPhone();
        allow create: if isVerifiedPhone()
                      && request.resource.data.customerId == request.auth.uid
                      && request.resource.data.rating is number
                      && request.resource.data.rating >= 1
                      && request.resource.data.rating <= 5;
        allow update, delete: if false;
      }
    }

    // ---- Jobs ----
    // Any verified technician may read jobs (the shared pool).
    // Create/update allowed for verified technicians; deletes denied from client.
    match /jobs/{jobId} {
      allow read:   if isVerifiedPhone();
      allow create: if isVerifiedPhone()
                    && request.resource.data.keys().hasAll(
                         ['customerName', 'address', 'phone', 'status']
                       );
      allow update: if isVerifiedPhone();
      allow delete: if false;
    }

    // ---- Inventory: verified techs can read and update stock counts ----
    match /inventory/{itemId} {
      allow read:   if isVerifiedPhone();
      allow update: if isVerifiedPhone();
      allow create: if isVerifiedPhone();
      allow delete: if false; // deletes via admin only
    }

    // ---- Customers: the techs' shared customer book ----
    // Verified techs read/update; creates are stamped with the author's uid;
    // deletes allowed (it's their own book — e.g. fixing a duplicate).
    match /customers/{customerId} {
      allow read:   if isVerifiedPhone();
      allow create: if isVerifiedPhone()
                    && request.resource.data.keys().hasAll(
                         ['name', 'phone', 'createdBy']
                       )
                    && request.resource.data.createdBy == request.auth.uid;
      allow update: if isVerifiedPhone();
      allow delete: if isVerifiedPhone();
    }

    // ---- Appointments (calendar) ----
    // Verified techs read/update; creates are stamped with the author's uid;
    // no client hard-delete — cancel via the `status` field instead.
    match /appointments/{apptId} {
      allow read:   if isVerifiedPhone();
      allow create: if isVerifiedPhone()
                    && request.resource.data.keys().hasAll(
                         ['startAt', 'status', 'createdBy']
                       )
                    && request.resource.data.createdBy == request.auth.uid;
      allow update: if isVerifiedPhone();
      allow delete: if false;
    }

    // ---- Catch-all: deny everything else ----
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

rules_version = '2';

// Araxis v2 — capability-based access control. Each user's capabilities live in
// their Firebase custom claim (`caps`), set only by the setUserCaps Cloud
// Function (Admin SDK). Deny by default.

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function capsMap() { return signedIn() ? request.auth.token.caps : null; }
    function provisioned() { return capsMap() != null; }            // an admin set this user up
    function can(name) { return provisioned() && request.auth.token.caps[name] == true; }

    // ---- Users ----
    // A user reads their own profile; a crew manager reads anyone (to add by
    // phone); otherwise you may read only your CREW MATES — users who share a
    // crew with you (`crewIds` intersect). Capabilities/crews are written ONLY by
    // the Cloud Functions; a user may self-edit name/services/availability.
    match /users/{userId} {
      allow read: if request.auth.uid == userId
                  || can('manageCrew')
                  || (provisioned()
                      && request.auth.token.crewIds is list
                      && resource.data.crewIds is list
                      && request.auth.token.crewIds.hasAny(resource.data.crewIds));
      allow create: if request.auth.uid == userId
                    && request.resource.data.uid == userId
                    && request.resource.data.teamId == ''
                    && request.resource.data.caps.manageCrew == false
                    && request.resource.data.caps.createCalls == false
                    && request.resource.data.caps.viewAllCalls == false
                    && request.resource.data.caps.viewFinancials == false
                    && request.resource.data.caps.viewTeamPayouts == false
                    && request.resource.data.caps.manageInventory == false;
      // A user may edit only their own `name`, `services` and `availability`.
      // Caps/crews are written solely by the Cloud Functions (Admin SDK).
      allow update: if request.auth.uid == userId
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['name', 'services', 'availability']);
      allow delete: if false;
    }

    // ---- Service calls ----
    match /serviceCalls/{ticketId} {
      allow read: if can('viewAllCalls')
                  || (provisioned()
                      && (resource.data.teamAssignment.leadTech == request.auth.uid
                          || request.auth.uid in resource.data.teamAssignment.assistants));
      allow create: if can('createCalls');
      allow update: if can('createCalls')
                    || (provisioned() && resource.data.teamAssignment.leadTech == request.auth.uid);
      allow delete: if can('createCalls');

      // Financials — gated by the viewFinancials capability (the wall).
      match /privateData/{docId} {
        allow read, write: if can('viewFinancials');
      }
    }

    // ---- Inventory ----
    match /inventory/{itemId} {
      allow read: if provisioned();
      allow write: if can('manageInventory');
    }

    // ---- Service catalog ----
    // Open list of service types. Any signed-in user can read it and add a new
    // one (e.g. during sign-up, before they're provisioned). No edits/deletes.
    match /services/{serviceId} {
      allow read, create: if signedIn();
    }

    // ---- Crews ----
    // A user reads crews they belong to. Crews are mutated only by the Cloud
    // Functions (Admin SDK), which also keep each member's caps claim in sync.
    match /crews/{crewId} {
      allow read: if signedIn() && request.auth.uid in resource.data.memberIds;
      allow write: if false;
    }

    // ---- Withdrawals (warehouse -> crew audit log) ----
    // Read/write limited to crews you belong to; the withdrawer must be you.
    // The matching warehouse stock change is gated by manageInventory on the
    // inventory doc (same batch), so only inventory managers can log a withdrawal.
    match /withdrawals/{wId} {
      allow read: if provisioned()
                  && request.auth.token.crewIds is list
                  && request.auth.token.crewIds.hasAny([resource.data.crewId]);
      allow create: if provisioned()
                    && request.auth.uid == request.resource.data.withdrawerId
                    && request.auth.token.crewIds is list
                    && request.auth.token.crewIds.hasAny([request.resource.data.crewId]);
      allow update, delete: if false;
    }
  }
}

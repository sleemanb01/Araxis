rules_version = '2';

// Araxis v2 — capability-based access control. Each user's capabilities live in
// their Firebase custom claim (`caps`), set only by the setUserCaps Cloud
// Function (Admin SDK). Deny by default.

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function capsMap() { return signedIn() ? request.auth.token.caps : null; }
    function provisioned() { return capsMap() != null; }            // an admin set this user up
    function can(name) { return provisioned() && request.auth.token.caps[name] == true; }

    // ---- Users ----
    // Provisioned crew can read profiles (to resolve names); a user always reads
    // their own. Capabilities/team are written ONLY by the Cloud Function (Admin
    // SDK bypasses rules); a user may self-register a no-capability profile and
    // later edit only their own `name`.
    match /users/{userId} {
      allow read: if provisioned() || request.auth.uid == userId;
      allow create: if request.auth.uid == userId
                    && request.resource.data.uid == userId
                    && request.resource.data.teamId == ''
                    && request.resource.data.caps.manageCrew == false
                    && request.resource.data.caps.createCalls == false
                    && request.resource.data.caps.viewAllCalls == false
                    && request.resource.data.caps.viewFinancials == false
                    && request.resource.data.caps.viewTeamPayouts == false
                    && request.resource.data.caps.manageInventory == false;
      // A user may edit only their own `name`; a crew manager may additionally
      // edit only their own `crew` roster array (a list of member uids).
      allow update: if request.auth.uid == userId
                    && (
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name'])
                      || (can('manageCrew')
                          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['crew']))
                    );
      allow delete: if false;
    }

    // ---- Service calls ----
    match /serviceCalls/{ticketId} {
      allow read: if can('viewAllCalls')
                  || (provisioned()
                      && (resource.data.teamAssignment.leadTech == request.auth.uid
                          || request.auth.uid in resource.data.teamAssignment.assistants));
      allow create: if can('createCalls');
      allow update: if can('createCalls')
                    || (provisioned() && resource.data.teamAssignment.leadTech == request.auth.uid);
      allow delete: if can('createCalls');

      // Financials — gated by the viewFinancials capability (the wall).
      match /privateData/{docId} {
        allow read, write: if can('viewFinancials');
      }
    }

    // ---- Inventory ----
    match /inventory/{itemId} {
      allow read: if provisioned();
      allow write: if can('manageInventory');
    }
  }
}

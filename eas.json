{
  "cli": {
    "version": ">= 20.3.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "environment": "development"
    },
    "preview": {
      "distribution": "internal",
      "environment": "preview"
    },
    "production": {
      "autoIncrement": true,
      "environment": "production"
    },
    "ios_simulator_development": {
      "developmentClient": true,
      "distribution": "internal",
      "environment": "development",
      "ios": {
        "buildConfiguration": "Debug",
        "simulator": true
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "sleeman.nabwani@gmail.com",
        "appleTeamId": "89F5K29LBN",
        "ascAppId": "6782345078"
      },
      "android": {
        "serviceAccountKeyPath": "./google-play-service-account.json",
        "track": "internal"
      }
    }
  }
}
